{
  "name": "nanoclaw",
  "version": "1.2.10",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "verify:node": "node scripts/check-node-version.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx tests/e2e-agent-flow.ts",
    "test:run": "bash tests/run-tests.sh",
    "test:minimal": "tsx tests/minimal-test.ts",
    "test:full": "tsx tests/full-agent-flow.ts",
    "security:scan": "tsx src/secret-scanner.ts",
    "security:audit": "npm audit"
  },
  "dependencies": {
    "@types/natural": "^6.0.1",
    "@types/node-cron": "^3.0.11",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3",
    "keytar": "^7.9.0",
    "natural": "^8.1.1",
    "node-cron": "^4.2.1",
    "node-llama-cpp": "^3.17.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/keytar": "^4.4.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
